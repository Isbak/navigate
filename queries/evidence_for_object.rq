# Evidence quotes backing each object: the traceable provenance of the graph.
PREFIX kg: <https://knowledge-atlas.local/kg/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?objectLabel ?artifact ?quote
WHERE {
    ?object kg:supportedBy ?evidence ;
            rdfs:label ?objectLabel .
    ?evidence kg:sourceArtifact ?artifact .
    OPTIONAL { ?evidence kg:quote ?quote }
}
ORDER BY ?objectLabel

# Navigate environment example
# -----------------------------------------------------------------------------
# Copy this file to .env for local development and replace placeholder values.
# Keep real secrets out of git. Most options are intentionally commented out so
# defaults from config/*.yml continue to work until you opt into an override.

# REST API authentication
# -----------------------------------------------------------------------------
# Used only when config/api.yml sets require_api_key: true. Requests must send
# Authorization: Bearer <this value>.
# NAVIGATE_API_KEY=change-me-to-a-long-random-token

# REST API storage overrides
# -----------------------------------------------------------------------------
# Optional overrides for config/api.yml db_path/cache_dir. Docker sets these to
# /data/* inside the API container; local development usually uses the defaults.
# NAVIGATE_DB=data/catalog.sqlite
# NAVIGATE_CACHE=cache

# Shared-group ownership for the SQLite DB and cache (Docker <-> host CLI)
# -----------------------------------------------------------------------------
# docker-compose runs the container as this UID:GID so it can write the
# bind-mounted ./data and ./cache that the host CLI also writes. SQLite needs
# write access to both the DB file and its directory (-wal/-shm/journal files).
# ./scripts/dev-permissions.sh fills these in for you (Compose reads .env
# automatically). Use NAVIGATE_UID/NAVIGATE_GID, not UID/GID — the latter are
# read-only in bash, so `export UID=...` silently no-ops.
# NAVIGATE_UID=1000
# NAVIGATE_GID=1000
#
# For a production deploy, run the same script under sudo with NAVIGATE_USER set
# to create/reuse a dedicated service account (and optionally BACKUP_DIR), e.g.
#   sudo NAVIGATE_USER=navigate BACKUP_DIR=/var/backups/navigate \
#       ./scripts/dev-permissions.sh

# LLM provider credentials
# -----------------------------------------------------------------------------
# config/llm.yml selects the active provider. The default provider is Claude,
# which requires ANTHROPIC_API_KEY when classification or GraphRAG is enabled.
# OpenAI is needed only if you switch config/llm.yml to provider: openai.
# ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key

# Optional local LLM service
# -----------------------------------------------------------------------------
# Ollama does not use an API key. Configure its host in config/llm.yml if you
# change it from the default http://localhost:11434.
# OLLAMA_HOST=http://localhost:11434

# Apache Jena Fuseki / RDF projection
# -----------------------------------------------------------------------------
# Fuseki connection details are read from config/jena.yml, not directly from
# environment variables. Keep these commented as copy/paste helpers for editing
# config/jena.yml or external tooling.
# FUSEKI_ENDPOINT=http://localhost:3030/knowledge-atlas
# FUSEKI_DATASET=atlas

# Docker Compose Fuseki admin password
# -----------------------------------------------------------------------------
# Used by docker-compose.yml for the local Fuseki service. Change this before
# exposing Fuseki beyond localhost.
FUSEKI_ADMIN_PASSWORD=change-me

# All approved teams, most confident first.
PREFIX kg: <https://knowledge-atlas.local/kg/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?team ?label ?confidence
WHERE {
    ?team a kg:Team .
    OPTIONAL { ?team rdfs:label ?label }
    OPTIONAL { ?team kg:confidence ?confidence }
}
ORDER BY DESC(?confidence)

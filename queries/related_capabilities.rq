# Capabilities directly related to another capability (any predicate).
PREFIX kg: <https://knowledge-atlas.local/kg/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?capabilityLabel ?predicate ?relatedLabel
WHERE {
    ?capability a kg:Capability ;
                rdfs:label ?capabilityLabel ;
                ?predicate ?related .
    ?related a kg:Capability ;
             rdfs:label ?relatedLabel .
    FILTER(?capability != ?related)
}
ORDER BY ?capabilityLabel

# Direct dependency edges: which object depends on which.
PREFIX kg: <https://knowledge-atlas.local/kg/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?dependentLabel ?dependencyLabel
WHERE {
    ?dependent kg:dependsOn ?dependency .
    ?dependent rdfs:label ?dependentLabel .
    ?dependency rdfs:label ?dependencyLabel .
}
ORDER BY ?dependentLabel

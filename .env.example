# LLM provider credentials. Claude is the default provider in config/llm.yml.
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Local Apache Jena Fuseki endpoint used by config/jena.yml and docker-compose.yml.
FUSEKI_ENDPOINT=http://localhost:3030/knowledge-atlas
FUSEKI_DATASET=atlas
